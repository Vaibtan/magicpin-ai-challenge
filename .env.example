# Anthropic primary (Sonnet 4.6 composer + Haiku 4.5 classifiers)
ANTHROPIC_API_KEY=

# OpenAI fallback (gpt-4o composer + gpt-4o-mini classifiers)
OPENAI_API_KEY=

# Set to 1 to load state_dump.json on startup. NEVER set in judge run.
BOT_DEV_MODE=0

# Optional override for run identifier in logs/run_{run_id}.jsonl
# Defaults to UTC timestamp at process start.
RUN_ID=
